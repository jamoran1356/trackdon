# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_DONACIONES_PROGRAM_ID=

# KYC provider — civic | truora | persona
KYC_PROVIDER=civic
KYC_API_KEY=
