# Supabase
NEXT_PUBLIC_SUPABASE_URL=
# Public key (safe to ship to the browser) — new format starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key — server-side only. NEVER ship in client bundle.
